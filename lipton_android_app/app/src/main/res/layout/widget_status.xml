<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ws_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/ws_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LIPTON VPN"
        android:textSize="8sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="#6CF0C3" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/ws_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/widget_button_bg"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/ws_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отключено"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EDFFF2" />

    </LinearLayout>

    <TextView
        android:id="@+id/ws_server"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text=""
        android:textSize="9sp"
        android:textColor="#8CB4F0C3"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
