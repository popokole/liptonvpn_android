<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LIPTON VPN"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="#6CF0C3" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Отключено"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#EDFFF2" />

    <LinearLayout
        android:id="@+id/widget_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:background="@drawable/widget_button_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_btn_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Подключить"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#000000" />
    </LinearLayout>

</LinearLayout>
