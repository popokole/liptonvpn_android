<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LiptonVPN" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.LiptonVPN.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_deep</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.LiptonVPN</item>
    </style>
</resources>
